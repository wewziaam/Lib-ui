local underToggleEnabled = false
local underEnabled       = false
local _underBP           = nil  -- persistent baseplate selama underground aktif
local _underOrigCF       = nil  -- simpan posisi asli sebelum turun

local function spawnUnderBP()
    if _underBP then pcall(function() _underBP:Destroy() end) end
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local bp = Instance.new("Part")
    bp.Name          = "UndergroundBP"
    bp.Size          = Vector3.new(999999, 1, 999999)  -- gede banget biar ga kelepasan
    bp.CFrame        = CFrame.new(hrp.Position.X, hrp.Position.Y - 10.5, hrp.Position.Z)
    bp.Anchored      = true
    bp.CanCollide    = true
    bp.Transparency  = 0  -- keliatan
    bp.CanTouch      = false
    bp.CastShadow    = false
    bp.Locked        = true
    bp.Parent        = workspace
    _underBP         = bp
end

local function destroyUnderBP()
    if _underBP then
        pcall(function() _underBP:Destroy() end)
        _underBP = nil
    end
end

local function startUnderground()
    local ch  = plr.Character
    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    -- Simpan posisi asli sebelum turun
    _underOrigCF = hrp.CFrame

    -- Spawn baseplate DULU sebelum tween turun biar ga void
    spawnUnderBP()
    task.wait(0.1) -- kasih waktu baseplate register physics

    -- Tween turun 4 studs
    local targetCF = hrp.CFrame - Vector3.new(0, 9, 0)
    local tw = TweenService:Create(
        hrp,
        TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { CFrame = targetCF }
    )
    tw:Play()
    tw.Completed:Wait()
end

local function stopUnderground()
    local ch  = plr.Character
    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
    if not hrp then destroyUnderBP(); return end

    -- Naik balik 8 studs dari posisi X Z SEKARANG (bukan dari posisi awal)
    -- Jadi cuma Y yang berubah, X Z ikut posisi karakter saat ini
    local currentCF = hrp.CFrame
    local upCF = CFrame.new(
        currentCF.X,
        currentCF.Y + 9,  -- naik 9 studs dari Y sekarang
        currentCF.Z
    ) * (currentCF - currentCF.Position)  -- pertahankan rotasi

    local tw = TweenService:Create(
        hrp,
        TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { CFrame = upCF }
    )
    tw:Play()
    tw.Completed:Wait()

    destroyUnderBP()
    _underOrigCF = nil
end

