-- ── ESP Distance Filter ───────────────────────────────────────────────────
-- SensoryESP ga punya MaxDistance built-in, jadi kita filter manual:
-- setiap Heartbeat, kalau player terlalu jauh → masukin ke Directories blacklist
-- kalau balik dalam range → keluarin dari blacklist
local _espFarBlacklist = {} -- [player] = true kalau lagi di-exclude
RunService.Heartbeat:Connect(function()
    if not _espLoaded then return end
    local cfg = pcall(function() return SensoryESP:GetConfig() end) and SensoryESP:GetConfig()
    if not cfg or not cfg.Enabled then return end
    local localRoot = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end

    for _, p in pairs(Players:GetPlayers()) do
        if p == plr then continue end
        local ch = p.Character
        local root = ch and ch:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local dist = (root.Position - localRoot.Position).Magnitude
        local tooFar = dist > ESPMaxDist
        local wasBlacklisted = _espFarBlacklist[p]

        if tooFar ~= wasBlacklisted then
            _espFarBlacklist[p] = tooFar
            pcall(function()
                -- Toggle player masuk/keluar Directories blacklist SensoryESP
                local dirs = cfg.Directories or {}
                if tooFar then
                    -- Tambah karakter ke blacklist
                    if ch and not table.find(dirs, ch) then
                        table.insert(dirs, ch)
                    end
                else
                    -- Hapus dari blacklist
                    local idx = ch and table.find(dirs, ch)
                    if idx then table.remove(dirs, idx) end
                end
                cfg.Directories = dirs
            end)
        end
    end
end)


