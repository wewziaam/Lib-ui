local CONFIG_FOLDER = "Hndrixx_Configs"
local HttpS = game:GetService("HttpService")
pcall(function() if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end end)

-- Get list of saved config names
local function getConfigList()
    local list = {}
    pcall(function()
        local files = listfiles(CONFIG_FOLDER)
        for _, path in ipairs(files) do
            local name = path:match("([^/\\]+)%.json$")
            if name then table.insert(list, name) end
        end
    end)
    table.sort(list)
    return list
end

-- Save current config
local function saveConfig(name)
    if not name or name == "" then return end
    pcall(function()
        local data = {}
        -- Read from getgenv().Options (where Kiwisense stores all UI elements)
        local opts = getgenv().Options
        if opts then
            for flag, option in pairs(opts) do
                pcall(function()
                    if option.Value ~= nil then
                        data[flag] = option.Value
                    end
                end)
            end
        end
        -- Fallback: also read from Library.Flags
        if Library.Flags then
            for flag, val in pairs(Library.Flags) do
                if data[flag] == nil and val ~= nil then
                    data[flag] = val
                end
            end
        end
        writefile(CONFIG_FOLDER .. "/" .. name .. ".json", HttpS:JSONEncode(data))
    end)
end

-- Load a config
local function loadConfig(name)
    if not name or name == "" then return end
    pcall(function()
        local path = CONFIG_FOLDER .. "/" .. name .. ".json"
        if not isfile(path) then return end
        local raw = readfile(path)
        if not raw or #raw < 3 then return end
        local data = HttpS:JSONDecode(raw)
        if type(data) ~= "table" then return end
        local opts = getgenv().Options
        for flag, val in pairs(data) do
            pcall(function()
                -- Method 1: Use getgenv().Options[flag]:Set() (Kiwisense native)
                if opts and opts[flag] and opts[flag].Set then
                    opts[flag]:Set(val)
                -- Method 2: Use Library.SetFlags[flag]() (registered by dropdowns/sliders)
                elseif Library.SetFlags and Library.SetFlags[flag] then
                    Library.SetFlags[flag](val)
                -- Method 3: Direct flag write (no UI update but at least sets value)
                elseif Library.Flags then
                    Library.Flags[flag] = val
                end
            end)
        end
    end)
end

-- Delete a config
local function deleteConfig(name)
    if not name or name == "" then return end
    pcall(function()
        local path = CONFIG_FOLDER .. "/" .. name .. ".json"
        if isfile(path) then delfile(path) end
    end)
end

