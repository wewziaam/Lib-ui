-- Hndrixx: tpToPos ke Pot+Y7 → fire → tpToPos ke Pot+Y16
local function af_TweenAndPrompt(Pot, Prompt, isApartment)
    if isApartment then
        -- Pakai af_Tween bukan af_TP — player sudah di dalam apt, jarak pendek
        -- af_TP (GO method) tidak perlu dan bikin loading screen sia-sia
        af_Tween(Pot.CFrame + Vector3.new(0,7,0))  -- turun ke level pot
        task.wait(0.5)
        af_FirePrompt(Prompt)
        task.wait(2.5)
        af_Tween(Pot.CFrame + Vector3.new(0,16,0))  -- naik ke atas (float)
    else
        af_FirePrompt(Prompt)
    end
end

-- ── Main Farm Function ────────────────────────────────────────
local function af_Start()
    AF.thread=task.spawn(function()
        while AF.active and Running do
            task.wait(1)
            if not AF.active then break end

            -- PHASE 1: Beli bahan di Lamont Bell ──────────────
            -- Loop pertama: Kill TP ke Lamont Bell
            -- Loop ke-2+: sudah di Lamont Bell (habis jual) → skip TP, langsung beli
            if AF.firstRun then
                AF.firstRun = false
                AF.phase = "Kill TP ke Lamont Bell..."
                doSuicideTP({name="Lamont Bell", x=510, y=4, z=602})
            end
            -- Loop ke-2+ tidak ada TP, langsung beli di bawah

            AF.phase = "Beli bahan di Lamont Bell..."
            local spRE=game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents",10)
            spRE=spRE and spRE:WaitForChild("StorePurchase",10)

            if spRE then
                for _,itemName in ipairs({"Gelatin","Sugar Block Bag","Water"}) do
                    if not AF.active then break end

                    -- Hitung dulu berapa yang udah ada (backpack + equipped)
                    local function countAll(name)
                        local n = af_CountBackpack(name)
                        if plr.Character then
                            for _,v in pairs(plr.Character:GetChildren()) do
                                if v:IsA("Tool") and v.Name==name then n=n+1 end
                            end
                        end
                        return n
                    end

                    local have = countAll(itemName)
                    local need = AF.amount - have  -- beli selisihnya aja

                    if need <= 0 then continue end  -- udah cukup, skip

                    AF.phase = "Beli "..itemName.." ("..have.."/"..AF.amount..")..."

                    for i=1,need do
                        if not AF.active then break end

                        -- Cek lagi setiap iterasi, bisa jadi udah cukup
                        if countAll(itemName) >= AF.amount then break end

                        -- Tunggu konfirmasi masuk backpack sebelum lanjut
                        local added = false
                        local conn; conn = plr.Backpack.ChildAdded:Connect(function(child)
                            if child.Name==itemName then added=true; conn:Disconnect() end
                        end)

                        -- Fire dengan timeout 5 detik biar ga stuck
                        local t = 0
                        repeat
                            pcall(function() spRE:FireServer(itemName) end)
                            task.wait(0.2)
                            t = t + 0.2
                        until added or t >= 5

                        if not added then
                            pcall(function() conn:Disconnect() end)
                        end

                        task.wait(0.1)
                    end

                    -- Final check setelah beli, notif kalau masih kurang
                    local finalHave = countAll(itemName)
                    if finalHave < AF.amount then
                        Library:Notification({
                            Name = "HNDRIXX | Farm",
                            Description = itemName.." kurang! Punya "..finalHave.."/"..AF.amount,
                            Duration = 2,
                        })
                    end

                    task.wait(0.3)
                end
            end

            if not AF.active then break end
            task.wait(1.5)

            -- PHASE 2: Cari / Beli Apartment ──────────────────
            AF.phase = "Cek apartment..."
            local House = af_GetHouse()

            if not House then
                -- Belum punya apt → cari yang VACANT dan beli
                local HouseToBuy = af_GetUnclaimedApt()
                if not HouseToBuy then
                    repeat task.wait(1); if not AF.active then break end
                        Library:Notification({Name="HNDRIXX | Farm",Description="Nunggu apt VACANT... coba hop server.",Duration=1})
                        HouseToBuy = af_GetUnclaimedApt()
                    until HouseToBuy
                end
                if not AF.active or not HouseToBuy then break end

                AF.phase = "Beli apartment..."
                local bb = HouseToBuy.Board and HouseToBuy.Board:FindFirstChild("backboard")
                if bb then af_TP(bb.CFrame) end  -- TP ke board (jauh, beda area)
                task.wait(1)
                af_FirePrompt(HouseToBuy.Board:FindFirstChildWhichIsA("ProximityPrompt",true))
                task.wait(1)
                House = af_GetHouse()
            else
                -- Sudah punya apt → TP langsung ke apt (dari Lamont Bell ke apt)
                -- Wajib af_TP bukan af_Tween karena jaraknya jauh
                AF.phase = "TP ke apartment..."
                local Interior = House:FindFirstChild("Interior") or House
                local Pot = Interior:FindFirstChild("Cooking Pot", true)
                if Pot then
                    af_TP(CFrame.new(Pot.Position.X, Pot.Position.Y + 3, Pot.Position.Z))
                else
                    -- Fallback: TP ke posisi House
                    local rootPart = House:FindFirstChildOfClass("BasePart")
                    if rootPart then af_TP(rootPart.CFrame) end
                end
            end

            if not AF.active or not House then break end

            -- PHASE 3: Buka pintu & lock pintu → Tween (deket) ─
            AF.phase="Buka & lock pintu..."
            local PersonalApt=af_GetPersonalApt()
            if PersonalApt and PersonalApt:FindFirstChild("Door") then
                local Door=PersonalApt.Door
                local Interact=Door:FindFirstChild("Interact")
                if Interact then
                    local rot=Interact.Rotation
                    local isOpen=rot==Vector3.new(0,90,0) or rot==Vector3.new(0,-90,0) or rot==Vector3.new(180,0,180)
                    if not isOpen then
                        -- Tween ke pintu (deket)
                        af_Tween(Interact.CFrame)
                        task.wait(0.5)
                        local openP=Interact:FindFirstChild("Attachment") and Interact.Attachment:FindFirstChildOfClass("ProximityPrompt")
                        if openP then af_FirePrompt(openP) end
                        task.wait(1)
                    end
                end
                local DoorLock=Door:FindFirstChild("DoorLock")
                if DoorLock then
                    local lockPart=DoorLock:FindFirstChild("Part")
                    if lockPart and lockPart.Rotation~=Vector3.new(90,0,0) then
                        -- Tween ke pintu (deket)
                        if Interact then af_Tween(Interact.CFrame) end
                        task.wait(0.5)
                        af_FirePrompt(lockPart:FindFirstChildOfClass("ProximityPrompt"))
                        task.wait(0.5)
                    end
                end
            end

            if not AF.active then break end

            -- PHASE 4: Setup interior & Cooking Pot → Tween ───
            local Interior=House:FindFirstChild("Interior") or House
            local isApt=House.Parent and House.Parent.Name=="Apartments"

            -- Disable floor collision
            for _,v in pairs(Interior:GetChildren()) do
                if v.Name=="Floor" then pcall(function() v.CanCollide=false end) end
            end

            local Pot=Interior:FindFirstChild("Cooking Pot",true)
            if not Pot then
                Library:Notification({Name="HNDRIXX | Farm",Description="Cooking Pot ga ketemu!",Duration=3})
                break
            end

            local PotAttach=Pot:FindFirstChildWhichIsA("Attachment",true)
            local PotPrompt=PotAttach and PotAttach:FindFirstChildOfClass("ProximityPrompt")
                         or Pot:FindFirstChildWhichIsA("ProximityPrompt",true)

            -- Tween ke pot (deket, udah di dalam apt)
            af_Tween(Pot.CFrame)

            -- Kalau bukan Apartments, tween turun ke bawah pot
            if not isApt then
                af_Tween(Pot.CFrame - Vector3.new(0,7,0))
            end

            -- ── PHASE 5: Handle step edge case → Tween ────────
            if AF.step=="Sugar Block Bag" then
                repeat task.wait() until Pot.Timer.TextLabel.Text=="0"
                af_Equip("Sugar Block Bag"); task.wait(1)
                af_TweenAndPrompt(Pot,PotPrompt,isApt)
                if not isApt then task.wait(2.5) end
                af_Unequip(); AF.step="Gelatin"
            end

            if AF.step=="Gelatin" then
                af_Unequip(); task.wait(1); af_Equip("Gelatin")
                local gelDied=false; local gelConn; gelConn=plr.Character.Humanoid.Died:Connect(function()
                    AF.step="Water"; gelDied=true; gelConn:Disconnect()
                end)
                af_TweenAndPrompt(Pot,PotPrompt,isApt)
                if not isApt then task.wait(2.5) end
                AF.step="Collect"; gelConn:Disconnect()
                if gelDied then AF.step="Water" end
            end

            if AF.step=="Collect" then
                repeat task.wait() until Pot.Timer.TextLabel.Text=="0"
                local colDied=false; local colConn; colConn=plr.Character.Humanoid.Died:Connect(function()
                    AF.step="Water"; colDied=true; colConn:Disconnect()
                end)
                af_Equip("Empty Bag"); task.wait(1)
                af_TweenAndPrompt(Pot,PotPrompt,isApt)
                if not isApt then task.wait(2.5) end
                af_Unequip(); AF.step="Water"; colConn:Disconnect()
            end

            -- ── PHASE 6: Main cook loop → Tween ───────────────
            if AF.step~="Sell" then
                local Water,Gel,Sug={},{},{}
                if plr.Backpack then for _,v in pairs(plr.Backpack:GetChildren()) do
                    if v.Name=="Sugar Block Bag" then table.insert(Sug,v)
                    elseif v.Name=="Gelatin" then table.insert(Gel,v)
                    elseif v.Name=="Water" then table.insert(Water,v) end
                end end

                local highestCommon=math.min(#Water,#Gel,#Sug)

                for i=1,highestCommon do
                    if not AF.active then break end

                    -- Water
                    if AF.step=="Water" then
                        AF.phase="Masak "..i.."/"..AF.amount.." — Water"
                        if not plr.Character:FindFirstChild("Water") then af_Equip("Water") end
                        task.wait(1)
                        af_TweenAndPrompt(Pot,PotPrompt,isApt)
                        if not isApt then task.wait(2.5) end
                        AF.step="Sugar Block Bag"
                    end

                    -- Sugar Block Bag
                    if AF.step=="Sugar Block Bag" then
                        AF.phase="Masak "..i.."/"..AF.amount.." — Sugar"
                        repeat task.wait() until Pot.Timer.TextLabel.Text=="0"
                        if not plr.Character:FindFirstChild("Sugar Block Bag") then af_Equip("Sugar Block Bag") end
                        task.wait(1)
                        af_TweenAndPrompt(Pot,PotPrompt,isApt)
                        if not isApt then task.wait(2.5) end
                        af_Unequip(); AF.step="Gelatin"
                    end

                    -- Gelatin
                    if AF.step=="Gelatin" then
                        AF.phase="Masak "..i.."/"..AF.amount.." — Gelatin"
                        repeat task.wait() until Pot.Timer.TextLabel.Text=="0"
                        local gelDied2=false; local gelConn2; gelConn2=plr.Character.Humanoid.Died:Connect(function()
                            AF.step="Water"; gelDied2=true; gelConn2:Disconnect()
                        end)
                        af_Unequip(); task.wait(1)
                        if not plr.Character:FindFirstChild("Gelatin") then af_Equip("Gelatin") end
                        af_TweenAndPrompt(Pot,PotPrompt,isApt)
                        if not isApt then task.wait(2.5) end
                        AF.step="Collect"; gelConn2:Disconnect()
                        if gelDied2 then break end
                    end

                    -- Collect (Empty Bag)
                    if AF.step=="Collect" then
                        AF.phase="Masak "..i.."/"..AF.amount.." — Empty Bag"
                        repeat task.wait() until Pot.Timer.TextLabel.Text=="0"
                        local colDied2=false; local colConn2; colConn2=plr.Character.Humanoid.Died:Connect(function()
                            AF.step="Water"; colDied2=true; colConn2:Disconnect()
                        end)
                        if not plr.Character:FindFirstChild("Empty Bag") then af_Equip("Empty Bag") end
                        task.wait(1)
                        af_TweenAndPrompt(Pot,PotPrompt,isApt)
                        task.wait(1)
                        af_Unequip()
                        AF.step=(i==AF.amount) and "Sell" or "Water"
                        colConn2:Disconnect()
                        if colDied2 then break end
                    end
                end
            end

            -- PHASE 7: Jual ke Lamont Bell ────────────────────
            -- GO ke Lamont Bell (jauh), Tween ke posisi NPC (deket)
            if AF.step=="Sell" and AF.active then
                AF.phase="Jual Marshmallow ke Lamont Bell..."
                af_TP(CFrame.new(510,4,602))
                repeat task.wait() until workspace.Folders.NPCs:FindFirstChild("Lamont Bell")
                task.wait(1)
                -- Tween ke posisi jual NPC (deket)
                af_Tween(CFrame.new(511,4,598))
                local lamont=workspace.Folders.NPCs:FindFirstChild("Lamont Bell")
                local sellP=lamont and lamont:FindFirstChild("UpperTorso")
                          and lamont.UpperTorso:FindFirstChildOfClass("ProximityPrompt")
                if plr.Backpack and sellP then
                    for _,v in pairs(plr.Backpack:GetChildren()) do
                        if not AF.active then break end
                        if v:IsA("Tool") and v.Name:find("Marshmallow") then
                            local hum2=plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
                            if hum2 then pcall(function() hum2:EquipTool(v) end) end
                            af_FirePrompt(sellP)
                            AF.sold=AF.sold+1
                            task.wait(0.25)
                        end
                    end
                end
                AF.step="Water"; AF.cycles=AF.cycles+1
                AF.phase="Siklus #"..AF.cycles.." selesai! Sold: "..AF.sold
            end
        end -- while

        AF.active=false; AF.phase=""
    end)
end

local function af_Stop()
    AF.active=false
    if AF.thread and coroutine.status(AF.thread)~="dead" then
        pcall(function() task.cancel(AF.thread) end)
    end
    AF.step="Water"; AF.phase=""
end

