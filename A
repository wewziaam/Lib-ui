-- ── Camera Noclip ────────────────────────────────────────────
-- Kamera bisa tembus tembok, tembok yang ditembus jadi semi transparan
local camNoclipEnabled = false
local _camTransparentParts = {} -- [BasePart] = originalTransparency
local _camNoclipConn = nil

local function restoreCamParts()
    for part, origTrans in pairs(_camTransparentParts) do
        pcall(function()
            if part and part.Parent then
                part.LocalTransparencyModifier = origTrans
            end
        end)
    end
    _camTransparentParts = {}
end

local _origCamType = nil

local function enableCamNoclip()
    if _camNoclipConn then return end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude

    -- Track parts yang kita disable CanQuery-nya
    local _noQueryParts = {}

    local function restoreQuery()
        for part, orig in pairs(_noQueryParts) do
            pcall(function()
                if part and part.Parent then
                    part.CanQuery = orig
                end
            end)
        end
        _noQueryParts = {}
    end

    _camNoclipConn = RunService.RenderStepped:Connect(function()
        local cam2 = workspace.CurrentCamera
        if not cam2 then return end
        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        rayParams.FilterDescendantsInstances = {plr.Character}

        local camPos = cam2.CFrame.Position
        local hrpPos = hrp.Position + Vector3.new(0, 1.5, 0)
        local dir    = hrpPos - camPos
        local dist   = dir.Magnitude

        local newNoQuery = {}
        local newTransparent = {}

        if dist > 0.1 then
            local checked   = {}
            local origin    = camPos
            local remaining = dist

            while remaining > 0.1 do
                local result = workspace:Raycast(origin, dir.Unit * remaining, rayParams)
                if not result then break end
                local part = result.Instance
                if part and part:IsA("BasePart") and not checked[part] then
                    checked[part] = true

                    -- Disable CanQuery biar kamera Roblox ga detect collision sama part ini
                    if newNoQuery[part] == nil then
                        newNoQuery[part] = part.CanQuery
                        pcall(function() part.CanQuery = false end)
                    end

                    -- Juga bikin transparan
                    local origTrans = (_camTransparentParts[part] ~= nil)
                        and _camTransparentParts[part]
                        or part.LocalTransparencyModifier
                    newTransparent[part] = origTrans
                    pcall(function() part.LocalTransparencyModifier = 0.7 end)
                end
                origin    = result.Position + dir.Unit * 0.01
                remaining = (hrpPos - origin).Magnitude
            end
        end

        -- Restore parts yang udah ga diblok
        for part, origQ in pairs(_noQueryParts) do
            if not newNoQuery[part] then
                pcall(function()
                    if part and part.Parent then part.CanQuery = origQ end
                end)
            end
        end
        for part, origT in pairs(_camTransparentParts) do
            if not newTransparent[part] then
                pcall(function()
                    if part and part.Parent then part.LocalTransparencyModifier = origT end
                end)
            end
        end

        _noQueryParts = newNoQuery
        _camTransparentParts = newTransparent
    end)
end

local function disableCamNoclip()
    if _camNoclipConn then
        _camNoclipConn:Disconnect()
        _camNoclipConn = nil
    end
    restoreCamParts()
end

