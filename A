-- CLEANUP: Reset all features on UI close (X button)
-- ══════════════════════════════════════════════════════════════
do
    local function cleanupAll()
        getgenv().__HndrixxLoaded = nil
        Running = false
        for k, _ in pairs(Flags) do Flags[k] = false end
        underEnabled = false; pcall(stopUnderground)
        pcall(disableCamNoclip)
        charFlyEnabled = false; charFlyActive = false
        vFlyActive = false; vStopFly()
        pcall(disableNoclip); pcall(detachStamina)
        Flags.AutoCook = false
        if AF then AF.active = false; AF.paused = false end
        boxActive = false
        pcall(function()
            local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = 16 end
        end)
        pcall(function() if _espLoaded then SensoryESP:Unload() end end)
        pcall(function() if SilentFovCircle then SilentFovCircle:Remove() end end)
        pcall(function() if SilentTracerLine then SilentTracerLine:Remove() end end)
        pcall(function() if AimFovCircle then AimFovCircle:Remove() end end)
        SilentAim = false; AimLock = false; AimTarget = nil
    end

    local origUnload = Library.Unload
    if origUnload then
        Library.Unload = function(...)
            cleanupAll()
            return origUnload(...)
        end
    end

    local mt = getmetatable(Library)
    if not mt then
        local origUnloadMethod = Library.Unload
        Library.Unload = function(self, ...)
            cleanupAll()
            if origUnloadMethod then return origUnloadMethod(self, ...) end
        end
    end
end
