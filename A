local AF = {active=false, paused=false, amount=5, phase="", sold=0, cycles=0, thread=nil, step="Water", firstRun=true}

-- ── Helper: Tween biasa ke CFrame (untuk jarak deket) ────────
local function af_Tween(cf)
    local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local dist=(hrp.Position-cf.Position).Magnitude
    local tw=TweenService:Create(hrp,TweenInfo.new(math.max(dist/20,0.05),Enum.EasingStyle.Linear),{CFrame=cf})
    tw:Play(); tw.Completed:Wait()
end

-- ── Helper: hitung item di backpack ──────────────────────────
local function af_CountBackpack(name)
    local n=0
    if plr.Backpack then for _,v in pairs(plr.Backpack:GetChildren()) do if v.Name==name then n=n+1 end end end
    return n
end

-- ── Helper: GetHouse — scan APTS cari Board nama == plr.Name ─
local function af_GetHouse()
    for _,apt in pairs(workspace.Map.APTS:GetChildren()) do
        local board=apt:FindFirstChild("Board")
        if board then
            local lbl=board:FindFirstChild("name",true); lbl=lbl and lbl:FindFirstChild("TextLabel",true)
            if lbl and lbl.Text==plr.Name then
                return workspace.Map.Houses:FindFirstChild(apt.Name)
                    or workspace.Map.Locations.Apartments:FindFirstChild(apt.Name)
            end
        end
    end
    return nil
end

-- ── Helper: GetUnclaimedApartment — VACANT + ada Cooking Pot ─
local function af_GetUnclaimedApt()
    for _,apt in pairs(workspace.Map.APTS:GetChildren()) do
        local nameObj=apt:FindFirstChild("name",true); local lbl=nameObj and nameObj:FindFirstChild("TextLabel",true)
        if lbl and lbl.Text=="VACANT" then
            local cache=workspace.Map.Locations.Apartments:FindFirstChild(apt.Name) or workspace.Map.Houses:FindFirstChild(apt.Name)
            if cache then
                local interior=cache:FindFirstChild("Interior") or cache
                if interior:FindFirstChild("Cooking Pot",true) then return apt end
            end
        end
    end
    return nil
end

-- ── Helper: GetPersonalApartment — APTS nama == plr.Name ─────
local function af_GetPersonalApt()
    for _,apt in pairs(workspace.Map.APTS:GetChildren()) do
        local nameObj=apt:FindFirstChild("name",true); local lbl=nameObj and nameObj:FindFirstChild("TextLabel",true)
        if lbl and lbl.Text==plr.Name then return apt end
    end
    return nil
end

-- ── Helper: TP pakai GO method (tpToPos) dari CFrame ─────────
local function af_TP(cf)
    local x,y,z
    if typeof(cf)=="CFrame" then x,y,z=cf.X,cf.Y,cf.Z
    elseif typeof(cf)=="Vector3" then x,y,z=cf.X,cf.Y,cf.Z
    else return end
    tpToPos(x,y,z)
    local w=0; while tpActive and w<200 do task.wait(0.1);w=w+1 end
    task.wait(0.3)
end

-- ── Helper: fireproximityprompt jarak jauh ───────────────────
